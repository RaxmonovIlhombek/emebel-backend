# Bu faylni .env deb saqlang va qiymatlarni o'zgartiring

# Xavfsizlik kaliti (ishga tushirishdan oldin albatta o'zgartiring!)
SECRET_KEY=django-insecure-mebel-crm-secret-key-change-in-production

# Debug rejimi: True (ishlab chiqishda), False (serverlarda)
DEBUG=True

# Ruxsat etilgan xostlar (vergul bilan ajrating)
ALLOWED_HOSTS=localhost,127.0.0.1
TELEGRAM_BOT_TOKEN=sizning_bot_tokeningiz
GROQ_API_KEY=gsk_sizning_api_keyingiz